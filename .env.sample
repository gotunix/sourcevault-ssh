# ============================================================
# SourceVault SSH — Environment Configuration Sample
# Copy this file to .env and fill in your values.
# Do NOT commit .env to version control.
# ============================================================

# --- User / Group IDs ---
# PUID/PGID for the 'git' user inside the container.
# Set these to match the UID/GID of the user that owns your repository
# data on the host or NFS volume to avoid permission issues.
PUID=401
PGID=401

# --- Bootstrap (First Admin) ---
# On first boot, if the database is empty, this public key is automatically
# registered as the 'admin' user with full admin privileges.
# Paste your full public key line here (the contents of ~/.ssh/id_ed25519.pub).
# Once the admin user is created this has no further effect — safe to leave set.
BOOTSTRAP_ADMIN_KEY=ssh-ed25519 AAAA...YOUR_KEY_HERE admin@yourhost

# --- Tailscale ---
# Auth key for the Tailscale sidecar container.
# Generate one at: https://login.tailscale.com/admin/settings/keys
TS_AUTHKEY=tskey-auth-REPLACE_ME

# --- Database ---
# Directory where sourcevault.db is stored. Must be on a local volume — NOT NFS.
# Defaults to /data (backed by the 'sourcevault-data' Docker named volume).
# For non-Docker use, set this to any local writable path.
SOURCEVAULT_DB_DIR=/data

# --- Logging ---
# Path inside the container where SSH access logs are written.
# The entrypoint tails this file to stdout so it appears in docker logs.
GIT_SHELL_LOG_PATH=/var/log/git/ssh.log
