# SourceVault SSH Configuration

# Identification of the first admin user (mandatory on first boot if no DB exists)
BOOTSTRAP_ADMIN_USER=admin
# Paste your personal public key here to seed the first admin account
BOOTSTRAP_ADMIN_KEY=ssh-ed25519 AAAA... comment

# Trusted Certificate Authority Bootstrap
# If these are set, SourceVault will trust any certificate signed by this CA.
BOOTSTRAP_CA_NAME=InitialCA
BOOTSTRAP_CA_IS_ADMIN=false
BOOTSTRAP_CA_KEY=ssh-ed25519 AAAA... comment

# Filesystem Paths
# SOURCEVAULT_DB_DIR must be a local volume (NOT NFS) for SQLite performance/locking.
SOURCEVAULT_DB_DIR=/data
GIT_SHELL_REPO_ROOT=/data/git
GIT_SHELL_LOG_PATH=/var/log/git/ssh.log

# Container Identities (should match your storage owner)
PUID=401
PGID=401
