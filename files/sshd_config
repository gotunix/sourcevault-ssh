Include /etc/ssh/sshd_config.d/*.conf

Port 22

#AllowGroups ssh_user

LoginGraceTime 1m
PermitRootLogin prohibit-password
MaxAuthTries 4
MaxSessions 10
PubkeyAuthentication yes

#RevokedKeys /etc/ssh/revoked_keys

Banner /etc/issue.net

PasswordAuthentication no
ChallengeResponseAuthentication no
UsePAM yes
X11Forwarding yes
PrintMotd no
PrintLastLog yes

AcceptEnv LANG LC_*
Subsystem   sftp    /usr/libexec/sftp-server
# Dynamically resolve SSH keys against the SourceVault SQLite database.
# sshd calls sv-shell with the connecting key's SHA256 fingerprint.
# sv-shell writes the authorized_keys line (including ForceCommand and env vars)
# to stdout, or nothing if the key is not registered (sshd denies access).
AuthorizedKeysCommand     /usr/local/bin/git-shell --keys %f
AuthorizedKeysCommandUser git

# Required for environment= options in the authorized_keys output to take effect.
# Allows GIT_USER and GIT_ADMIN to be injected into the session.
PermitUserEnvironment yes

# Allow admin users to connect interactively (no-pty restriction is lifted
# per-key by omitting it from the authorized_keys line for admin sessions).
# Standard git sessions have no-pty enforced by the key resolver output.

Match User git
    # No ForceCommand here — the command= option in the authorized_keys output
    # produced by AuthorizedKeysCommand acts as the per-key ForceCommand.
    # This keeps all access control logic inside sv-shell.
    AllowTcpForwarding no
    X11Forwarding no

# Required for SSH certificate identity resolution.
# Writes auth info to a file pointed to by $SSH_USER_AUTH.
ExposeAuthInfo yes

# Trust the CA public key for initial certificate validation.
# The entrypoint script ensures this file exists at /etc/ssh/ca.pub.
TrustedUserCAKeys /etc/ssh/ca.pub
